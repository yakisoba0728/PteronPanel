# Pterodactyl Panel
PANEL_URL="https://panel.example.com"
PTERO_APP_KEY="ptla_xxxxxxxxxxxxxxxxxxxxxxxx"     # Application API key (Admin -> Application API)
PTERO_CLIENT_KEY="ptlc_xxxxxxxxxxxxxxxxxxxxxxxx"  # Client API key of a ROOT ADMIN user (Account -> API Credentials)

# Database
DATABASE_URL="postgresql://pteron:pteron@db:5432/pteron?schema=public"

# App
SESSION_SECRET="change-me-min-16-chars"
APP_BASE_URL="http://localhost:3000"
SESSION_TTL_HOURS="12"
LOG_LEVEL="info"
# Set only for local/e2e webhook receivers. Production defaults reject localhost/private webhook URLs.
PTERON_ALLOW_LOCAL_WEBHOOKS="0"

# Seed (prisma db:seed)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="change-me-admin"
SEED_USER_EMAIL="user@example.com"          # Must exist in Pterodactyl to get a mapping
SEED_USER_USERNAME="user"
SEED_USER_PASSWORD="change-me-user"
